jQuery(document).ready(function ($) {
  if ($(".vedautrang").length > 0) {
    $(window).scroll(function () {
      var e = $(window).scrollTop();
      if (e > 300) {
        $(".vedautrang").show();
      } else {
        $(".vedautrang").hide();
      }
    });
    $(".vedautrang").click(function () {
      $("body,html").animate({
        scrollTop: 0,
      });
    });
  }
  /*-----tốc độ cuộn---------*/
  $('a[href*="#"]')
    .not('[href="#"]')
    .not('[href="#0"]')
    .click(function (e) {
      var data_id = $(this).attr("href");
      $("html, body").animate(
        {
          scrollTop: $(data_id).offset().top - 200,
        },
        "5000"
      );
    });
});
